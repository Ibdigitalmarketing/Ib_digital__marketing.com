<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>IB STUDIO - Cinematic & Photography | Adamawa</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;700&display=swap');
  
    * { margin: 0; padding: 0; box-sizing: border-box; }
  
  :root {
    --bg: #000;
    --bg-card: #111;
    --gold: #FFD700;
    --red: #DC2626;
    --white: #ffffff;
    --gray: #9ca3af;
    --border: rgba(255, 215, 0, 0.15);
  }
  
  html { 
    scroll-behavior: smooth; 
    font-size: clamp(14px, 1.1vw, 16px);
  }
  
  body {
    background: var(--bg);
    color: var(--white);
    font-family: 'Outfit', sans-serif;
    line-height: 1.5;
    overflow-x: hidden;
    width: 100%;
  }
  
  /* Cinematic Film Grain Overlay */
  body::after {
    content: '';
    position: fixed; inset: 0;
    background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="4" stitchTiles="stitch"/></filter><rect width="100%" height="100%" filter="url(%23noise)" opacity="0.03"/></svg>');
    pointer-events: none; z-index: 999;
  }
  
  /* Container Auto-fit */
  .container {
    width: 100%;
    max-width: min(94vw, 1500px);
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 50px);
  }
  
  /* Header - Minimal Cinematic */
  header {
    position: fixed; top: 0; left: 0; right: 0;
    width: 100%;
    padding: clamp(20px, 2.5vw, 30px) clamp(20px, 4vw, 50px);
    display: flex; justify-content: space-between; align-items: center;
    background: linear-gradient(180deg, rgba(0,0,0,0.9) 0%, transparent 100%);
    backdrop-filter: blur(10px);
    z-index: 1000;
    border-bottom: 1px solid transparent;
    transition: 0.4s;
  }
  
  header.scrolled {
    background: rgba(0,0,0,0.95);
    border-bottom-color: var(--border);
  }
  
  .logo-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--white);
    letter-spacing: 4px;
    text-shadow: 0 0 30px rgba(255, 215, 0, 0.3);
  }
  
  nav {
    display: flex; gap: clamp(25px, 4vw, 45px);
  }
  
  nav a {
    color: var(--gray); text-decoration: none;
    font-weight: 400; font-size: clamp(0.85rem, 1.2vw, 0.95rem);
    letter-spacing: 2px; text-transform: uppercase;
    transition: 0.3s; position: relative;
  }
  
  nav a::before {
    content: ''; position: absolute; bottom: -8px; left: 50%;
    width: 0; height: 2px; background: var(--gold);
    transition: 0.3s; transform: translateX(-50%);
  }
  
  nav a:hover { color: var(--gold); }
  nav a:hover::before { width: 100%; }
  
  .btn-red {
    background: var(--red);
    color: white; padding: clamp(12px, 1.5vw, 16px) clamp(28px, 3.5vw, 36px);
    border: none; font-weight: 700; font-size: clamp(0.8rem, 1.2vw, 0.9rem);
    letter-spacing: 2px; text-transform: uppercase;
    cursor: pointer; transition: 0.4s; border-radius: 4px;
    box-shadow: 0 8px 25px rgba(220, 38, 38, 0.3);
  }
  
  .btn-red:hover { 
    background: #b91c1c; 
    transform: scale(1.05);
    box-shadow: 0 12px 40px rgba(220, 38, 38, 0.5);
  }
  
  /* Hero - Full Screen Cinematic */
  .hero {
    min-height: 100svh;
    display: flex; flex-direction: column;
    justify-content: center; align-items: center;
    padding: clamp(100px, 15vh, 150px) clamp(20px, 4vw, 50px);
    text-align: center; position: relative;
    background: radial-gradient(circle at 50% 50%, rgba(220, 38, 38, 0.15) 0%, transparent 60%),
                url('https://images.unsplash.com/photo-1506905925346-21b330104975?w=2000') center/cover;
  }
  
  .hero::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.9) 100%);
  }
  
  .hero-content {
    position: relative; z-index: 2; width: 100%;
  }
  
  .hero-logo {
    width: clamp(250px, 45vw, 420px);
    max-width: 90%;
    margin-bottom: clamp(40px, 6vw, 60px);
    filter: drop-shadow(0 0 50px rgba(255, 215, 0, 0.4));
    animation: pulse-glow 4s ease-in-out infinite;
  }
  
  @keyframes pulse-glow {
    0%, 100% { filter: drop-shadow(0 0 50px rgba(255, 215, 0, 0.4)); }
    50% { filter: drop-shadow(0 0 80px rgba(255, 215, 0, 0.7)); }
  }
  
  .hero h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 12vw, 9rem);
    font-weight: 400;
    color: var(--white);
    letter-spacing: clamp(5px, 1.5vw, 15px);
    line-height: 0.85;
    margin-bottom: clamp(20px, 3vw, 30px);
    text-shadow: 0 10px 40px rgba(0,0,0,0.8);
    animation: text-glitch 3s infinite;
  }
  
  @keyframes text-glitch {
    0%, 100% { text-shadow: 0 10px 40px rgba(0,0,0,0.8), 2px 0 var(--gold), -2px 0 var(--red); }
    25% { text-shadow: 0 10px 40px rgba(0,0,0,0.8), -2px 0 var(--gold), 2px 0 var(--red); }
    50% { text-shadow: 0 10px 40px rgba(0,0,0,0.8), 2px 0 var(--gold), -2px 0 var(--red); }
    75% { text-shadow: 0 10px 40px rgba(0,0,0,0.8), -1px 0 var(--gold), 1px 0 var(--red); }
  }
  
  .hero p {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    color: #e5e7eb; max-width: min(90%, 750px);
    margin: 0 auto clamp(40px, 5vw, 50px);
    font-weight: 300; letter-spacing: 1px;
  }
  
  .hero-divider {
    width: clamp(100px, 20vw, 200px);
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin: clamp(30px, 4vw, 40px) auto;
  }
  
  /* Section Base */
  section {
    padding: clamp(100px, 12vw, 140px) clamp(20px, 4vw, 50px);
    width: 100%; position: relative;
  }
  
  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3.5rem, 8vw, 6rem);
    color: var(--white); text-align: center;
    margin-bottom: clamp(20px, 3vw, 30px);
    letter-spacing: clamp(3px, 1vw, 8px);
    line-height: 0.9;
  }
  
  .section-title .gold { color: var(--gold); }
  
  .section-subtitle {
    color: var(--gray); text-align: center;
    margin-bottom: clamp(70px, 9vw, 100px); font-size: clamp(1rem, 1.7vw, 1.2rem);
    max-width: min(90%, 650px); margin-left: auto; margin-right: auto;
  }
  
  /* Services - Split Layout */
  .services {
    background: var(--bg-card);
    border-top: 1px solid var(--border);
  }
  
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 350px), 1fr));
    gap: clamp(40px, 5vw, 60px);
  }
  
  .service-card {
    background: linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 100%);
    border: 1px solid var(--border);
    padding: clamp(45px, 6vw, 60px) clamp(35px, 5vw, 45px);
    position: relative; overflow: hidden;
    transition: 0.5s;
  }
  
  .service-card::before {
    content: ''; position: absolute; top: 0; left: 0;
    width: 100%; height: 4px;
    background: linear-gradient(90deg, var(--red), var(--gold));
    transform: scaleX(0); transition: 0.5s; transform-origin: left;
  }
  
  .service-card:hover::before { transform: scaleX(1); }
  .service-card:hover { 
    transform: translateY(-15px);
    border-color: var(--gold);
    box-shadow: 0 30px 70px rgba(255, 215, 0, 0.15);
  }
  
  .service-number {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 8vw, 6rem);
    color: rgba(255, 215, 0, 0.08);
    position: absolute; top: 20px; right: 30px;
    line-height: 1;
  }
  
  .service-card h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 4vw, 3.2rem); color: var(--white);
    margin-bottom: clamp(20px, 3vw, 25px); letter-spacing: 3px;
    position: relative;
  }
  
  .service-card p {
    color: var(--gray); margin-bottom: clamp(25px, 4vw, 35px);
    font-size: clamp(1rem, 1.5vw, 1.1rem);
  }
  
  .price-tag {
    display: inline-block;
    background: var(--red);
    color: white; padding: clamp(10px, 1.5vw, 12px) clamp(20px, 3vw, 25px);
    font-weight: 700; font-size: clamp(1.2rem, 2vw, 1.5rem);
    letter-spacing: 1px; border-radius: 4px;
  }
  
  /* Portfolio - Masonry Grid */
  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    grid-auto-rows: clamp(300px, 40vw, 450px);
    gap: clamp(20px, 3vw, 30px);
  }
  
  .portfolio-item {
    position: relative; overflow: hidden;
    cursor: pointer; border: 1px solid var(--border);
  }
  
  .portfolio-item:nth-child(3n) {
    grid-row: span 2; /* Make every 3rd item taller for masonry effect */
  }
  
  .portfolio-item img {
    width: 100%; height: 100%; object-fit: cover;
    transition: 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    filter: grayscale(100%) brightness(0.6);
  }
  
  .portfolio-item:hover img {
    transform: scale(1.15);
    filter: grayscale(0%) brightness(1);
  }
  
  .portfolio-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(0,0,0,0.95) 100%);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: clamp(30px, 4vw, 40px);
    opacity: 0; transform: translateY(30px);
    transition: 0.5s;
  }
  
  .portfolio-item:hover .portfolio-overlay {
    opacity: 1; transform: translateY(0);
  }
  
  .portfolio-overlay h4 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2rem, 3.5vw, 2.8rem); color: var(--gold);
    letter-spacing: 2px; margin-bottom: 10px;
  }
  
  /* Contact - Cinematic CTA */
  .contact {
    background: linear-gradient(180deg, var(--bg) 0%, #0a0a0a 100%);
    border-top: 1px solid var(--border);
    text-align: center;
  }
  
  .contact-box {
    border: 2px solid var(--gold);
    padding: clamp(60px, 8vw, 90px) clamp(30px, 5vw, 60px);
    background: rgba(255, 215, 0, 0.03);
    position: relative;
  }
  
  .contact-box::before {
    content: 'BOOK NOW';
    position: absolute; top: -15px; left: 50%;
    transform: translateX(-50%);
    background: var(--bg);
    padding: 0 clamp(20px, 3vw, 30px);
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    color: var(--gold); letter-spacing: 4px;
  }
  
  .contact-number {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3.5rem, 7vw, 5.5rem); color: var(--gold);
    letter-spacing: 4px; margin: clamp(30px, 4vw, 40px) 0;
    word-break: break-all;
  }
  
  footer {
    padding: clamp(40px, 5vw, 60px) clamp(20px, 4vw, 50px); text-align: center;
    border-top: 1px solid var(--border); color: var(--gray);
    font-size: clamp(0.85rem, 1.2vw, 0.95rem); letter-spacing: 2px;
  }
  
  /* Mobile */
  @media (max-width: 768px) {
    nav { display: none; }
    .hero h1 { font-size: clamp(3.5rem, 15vw, 5rem); }
    .portfolio-item:nth-child(3n) { grid-row: span 1; }
  }
</style>
</head>
<body>
  
  <header id="header">
